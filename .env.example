# ── Server ────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Dashboard Auth ────────────────────────────────────
DASHBOARD_USER=Bibekjyoti
DASHBOARD_PASS=Bibek@7085

# ── Model Hyperparameters ─────────────────────────────
# Defaults (no .env) = 128/2/30 — matches saved checkpoints.
# To switch to VPS-optimised smaller model, set values below
# AND delete model/checkpoints/*.pt before first start
# (architecture mismatch will silently break checkpoint load).
SEQUENCE_LENGTH=30         # VPS: 20
HIDDEN_SIZE=128            # VPS: 64
NUM_LAYERS=2               # VPS: 1
BATCH_SIZE=64
LEARNING_RATE=0.001
CONFIDENCE_THRESHOLD=0.55

# ── VPS CPU Throttling ────────────────────────────────
# Limits PyTorch threads — critical on shared-core VPS
TORCH_THREADS=1            # set 2 if VPS has 2 vCPU
# Startup fine-tune epochs (checkpoint already trained)
STARTUP_EPOCHS=3           # 15 on big machine
# Background continuous retraining
CONTINUOUS_EPOCHS=5        # 10 on big machine
CONTINUOUS_INTERVAL=3600   # seconds — 3600=60min, 1800=30min
# Per-timer retrain window (most recent N rows, 0=all data).
# 30sec timer generates ~120 results/hr — needs larger window.
# Predictions are ALWAYS real-time; this only throttles background weight updates.
RETRAIN_WINDOW_30SEC=3000        # VPS: 2000  (~17hrs at 120/hr)
RETRAIN_WINDOW_1MIN=1500         # VPS: 1000  (~17hrs at 60/hr)
RETRAIN_WINDOW_3MIN=1000         # VPS: 500   (~25hrs at 20/hr)
# Online weight-update throttle: backprop every N new results per timer.
# Does NOT affect prediction frequency — predictions fire on every result.
# 5 = every 2.5min for 30sec, every 5min for 1min. Fine on any VPS.
ONLINE_UPDATE_EVERY=5            # VPS: 5 (same — thread pool handles it)

# ── IMPORTANT: changing HIDDEN_SIZE or NUM_LAYERS ─────
# requires clearing model/checkpoints/*.pt before restart
# otherwise the server will fail to load the old checkpoint

# ── Game settings (legacy) ────────────────────────────
GAME_INTERVAL=3
PHONE_NUMBER=
PASSWORD=
